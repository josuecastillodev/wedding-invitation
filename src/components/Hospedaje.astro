---
import { EVENT_CONFIG } from '../config/event';
const baseUrl = EVENT_CONFIG.baseUrl;
---

<section class="px-6 py-16 text-center">
  <!-- Title -->
  <h2
    data-animate
    class="font-serif text-2xl md:text-3xl uppercase tracking-[0.15em] text-text-dark"
  >
    Hospedaje
  </h2>

  <!-- Hotel Name -->
  <p
    data-animate
    data-delay="100"
    class="font-script text-[#4a4c35] text-3xl md:text-6xl mt-2"
  >
    Holiday Inn Express
    <br>
    Guadalajara Vallarta Poniente by IHG
  </p>

  <!-- Content: Image + Buttons -->
  <div
    data-animate
    data-delay="200"
    class="mt-8 md:mt-12 flex flex-col md:flex-row md:items-center md:justify-center gap-8 md:gap-16"
  >
    <!-- Image -->
    <div class="w-full md:w-auto">
      <img
        src={`${baseUrl}/images/hospedaje.jpg`}
        alt="Hotel"
        loading="lazy"
        class="w-full md:w-[400px] lg:w-[500px] h-auto object-cover"
      />
    </div>

    <!-- Buttons -->
    <div class="flex flex-col gap-4 items-center md:items-start w-full max-w-sm">
      <!-- <a
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        class="w-full py-3 px-6 bg-burgundy text-white font-serif text-base md:text-lg tracking-wide text-center hover:bg-burgundy/90 transition-colors"
      >
        Quiero Reservar
      </a> -->
      <a
        href="https://www.ihg.com/holidayinnexpress/hotels/us/en/guadalajara/gdlqp/hoteldetail?cm_mmc=GoogleMaps-_-EX-_-MX-_-GDLQP"
        target="_blank"
        rel="noopener noreferrer"
        class="w-full py-3 px-6 bg-[#847d63] text-white font-serif text-base md:text-lg tracking-wide text-center hover:bg-[#847d63]/80 transition-colors"
      >
        Más Sobre El Hotel
      </a>
      <!-- <a
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        class="w-full py-3 px-6 bg-mauve text-burgundy font-serif text-base md:text-lg tracking-wide text-center hover:bg-mauve/80 transition-colors"
      >
        Planes De Pago
      </a> -->
    </div>
  </div>

  <!-- Hotel Name -->
  <p
    data-animate
    data-delay="100"
    class="font-script text-[#4a4c35] text-3xl md:text-6xl mt-8"
  >
    Hotel NG Ameca
  </p>

  <!-- Content: Image + Buttons -->
  <div
    data-animate
    data-delay="200"
    class="mt-8 md:mt-12 flex flex-col md:flex-row md:items-center md:justify-center gap-8 md:gap-16"
  >
    <!-- Image -->
    <div class="w-full md:w-auto">
      <img
        src={`${baseUrl}/images/hospedaje02.jpg`}
        alt="Hotel"
        loading="lazy"
        class="w-full md:w-[400px] lg:w-[500px] h-auto object-cover"
      />
    </div>

    <!-- Buttons -->
    <div class="flex flex-col gap-4 items-center md:items-start w-full max-w-sm">
      <!-- <a
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        class="w-full py-3 px-6 bg-burgundy text-white font-serif text-base md:text-lg tracking-wide text-center hover:bg-burgundy/90 transition-colors"
      >
        Quiero Reservar
      </a> -->
      <a
        href="https://hotelngameca.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="w-full py-3 px-6 bg-[#847d63] text-white font-serif text-base md:text-lg tracking-wide text-center hover:bg-[#847d63]/80 transition-colors"
      >
        Más Sobre El Hotel
      </a>
      <!-- <a
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        class="w-full py-3 px-6 bg-mauve text-burgundy font-serif text-base md:text-lg tracking-wide text-center hover:bg-mauve/80 transition-colors"
      >
        Planes De Pago
      </a> -->
    </div>
  </div>
</section>
